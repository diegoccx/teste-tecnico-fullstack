# =============================================================================
# Intellux Drive — Variáveis de Ambiente do Backend
# Copie este arquivo para .env e preencha os valores antes de rodar a aplicação.
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
NODE_ENV=development          # development | production
PORT=3001                     # Porta HTTP em que a API vai escutar
FRONTEND_URL=http://localhost:5173  # Origem CORS permitida (URL da Vercel em produção)

# -----------------------------------------------------------------------------
# Banco de Dados (MySQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=intellux
DB_PASSWORD=change_me
DB_DATABASE=intellux_drive

# -----------------------------------------------------------------------------
# Autenticação
# -----------------------------------------------------------------------------
# Gere um secret seguro com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Armazenamento de Arquivos — Disco Local (padrão)
# Usado quando as credenciais AWS abaixo não estiverem configuradas.
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads          # Caminho para salvar os arquivos enviados
MAX_FILE_SIZE=10485760        # Tamanho máximo de upload em bytes (padrão: 10 MB)

# -----------------------------------------------------------------------------
# Armazenamento de Arquivos — AWS S3 (opcional, substitui o disco local quando
# todas as 4 variáveis abaixo estiverem preenchidas)
#
# Permissões IAM necessárias no bucket:
#   s3:PutObject, s3:DeleteObject, s3:GetObject
#
# Recomendado: crie um usuário IAM dedicado com a política abaixo e use suas
# chaves de acesso programático (nunca use as chaves da conta root em produção).
#
# Política IAM mínima:
# {
#   "Version": "2012-10-17",
#   "Statement": [{
#     "Effect": "Allow",
#     "Action": ["s3:PutObject", "s3:DeleteObject", "s3:GetObject"],
#     "Resource": "arn:aws:s3:::NOME_DO_SEU_BUCKET/*"
#   }]
# }
#
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=            # ID da chave de acesso do usuário IAM 
AWS_SECRET_ACCESS_KEY=        # Chave secreta de acesso do usuário IAM
AWS_REGION=us-east-1          # Região AWS onde o bucket está criado
AWS_S3_BUCKET=                # Nome do bucket (ex: intellux-drive-files-prod)
